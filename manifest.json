{
  "name": "cortex-plugin-obsidian",
  "version": "1.0.2",
  "description": "Read/write to local Obsidian vaults, create wiki-links",
  "kind": "esm",
  "entryPoint": "mod.ts",
  "runtime": "deno",
  "author": "CortexPrism",
  "license": "MIT",
  "repository": "https://github.com/CortexPrism/cortex-plugin-obsidian",
  "homepage": "https://github.com/CortexPrism/cortex-plugin-obsidian",
  "capabilities": [
    "tools",
    "fs:read",
    "fs:write",
    "fs:list"
  ],
  "tools": [
    {
      "name": "obsidian_read_note",
      "description": "Read a note from the vault",
      "params": [
        {
          "name": "path",
          "type": "string",
          "description": "Path to note relative to vault root",
          "required": true
        },
        {
          "name": "vault_path",
          "type": "string",
          "description": "Override default vault path",
          "required": false
        }
      ]
    },
    {
      "name": "obsidian_write_note",
      "description": "Write or update a note",
      "params": [
        {
          "name": "path",
          "type": "string",
          "description": "Path to note relative to vault root",
          "required": true
        },
        {
          "name": "content",
          "type": "string",
          "description": "Note content (Markdown)",
          "required": true
        },
        {
          "name": "frontmatter",
          "type": "string",
          "description": "JSON string of frontmatter key-values",
          "required": false
        }
      ]
    },
    {
      "name": "obsidian_search_vault",
      "description": "Search notes in the vault",
      "params": [
        {
          "name": "query",
          "type": "string",
          "description": "Search query",
          "required": true
        },
        {
          "name": "max_results",
          "type": "number",
          "description": "Maximum number of results",
          "required": false,
          "default": 20
        },
        {
          "name": "search_content",
          "type": "boolean",
          "description": "Search note content in addition to titles",
          "required": false,
          "default": true
        }
      ]
    },
    {
      "name": "obsidian_list_notes",
      "description": "List notes in a directory",
      "params": [
        {
          "name": "directory",
          "type": "string",
          "description": "Directory relative to vault root",
          "required": false,
          "default": "/"
        },
        {
          "name": "recursive",
          "type": "boolean",
          "description": "List recursively",
          "required": false,
          "default": false
        },
        {
          "name": "pattern",
          "type": "string",
          "description": "Glob pattern to filter notes",
          "required": false
        }
      ]
    },
    {
      "name": "obsidian_create_wikilink",
      "description": "Create wiki-style links between notes",
      "params": [
        {
          "name": "from_note",
          "type": "string",
          "description": "Source note path",
          "required": true
        },
        {
          "name": "to_note",
          "type": "string",
          "description": "Target note path",
          "required": true
        },
        {
          "name": "alias",
          "type": "string",
          "description": "Display alias for the link",
          "required": false
        }
      ]
    },
    {
      "name": "obsidian_graph",
      "description": "Get the note graph (linked notes)",
      "params": [
        {
          "name": "root_note",
          "type": "string",
          "description": "Root note to start from",
          "required": false
        },
        {
          "name": "max_depth",
          "type": "number",
          "description": "Maximum traversal depth",
          "required": false,
          "default": 2
        }
      ]
    }
  ],
  "ui": {
    "settings": [
      {
        "section": "Vault",
        "fields": [
          {
            "key": "vaultPath",
            "label": "Vault Path",
            "type": "text",
            "description": "Absolute path to Obsidian vault",
            "required": true
          }
        ]
      }
    ]
  },
  "dependencies": {},
  "peerDependencies": {
    "cortex": ">=1.0.0"
  },
  "aiDisclosure": {
    "tools": [
      "Claude Code (Anthropic)"
    ],
    "humanReview": true
  }
}
